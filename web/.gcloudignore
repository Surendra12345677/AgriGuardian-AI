# web/.gcloudignore — applied when `gcloud run deploy` is invoked with
# CWD = web/ (frontend service). Drops heavy local-only artefacts so the
# Cloud Build upload stays small.

node_modules/
.next/
.vercel/
out/
.env
.env.*
!.env.example
.git/
.gitignore
.idea/
.vscode/
.DS_Store
tsconfig.tsbuildinfo
*.log

