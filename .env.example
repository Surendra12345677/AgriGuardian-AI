# ──────────────────────────────────────────────────────────────
# AgriGuardian AI — environment variables template
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored so secrets never reach the repo.
# ──────────────────────────────────────────────────────────────

# ===== Arize (observability + MCP) =====
# Get an API key: https://app.arize.com/  →  Settings → API Keys → Create
# Use a Service Key with Member role (least privilege).
ARIZE_ENABLED=true
ARIZE_API_KEY=ak-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARIZE_SPACE_ID=U3BhY2U6xxxxxxxxxxxxx
ARIZE_OTLP_ENDPOINT=https://otlp.arize.com/v1
# Optional — if your Arize space exposes an MCP endpoint, paste it here.
ARIZE_MCP_URL=

# ===== Gemini =====
# Get a free API key: https://aistudio.google.com/app/apikey
# Leave blank to use the deterministic stub (app still boots).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# auto = use stub when key is missing | always = always stub | never = always real
GEMINI_STUB_MODE=auto

# ===== MongoDB =====
MONGODB_URI=mongodb://localhost:27017/agriguardian

# ===== App =====
PORT=8080
SPRING_PROFILES_ACTIVE=dev

