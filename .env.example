# ──────────────────────────────────────────────────────────────
# AgriGuardian AI — environment variables template
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored so secrets never reach the repo.
# ──────────────────────────────────────────────────────────────


# ===== Gemini =====
# Get a free API key: https://aistudio.google.com/app/apikey
# Leave blank to use the deterministic stub (app still boots).
GEMINI_API_KEY=
# Hackathon requires Gemini 3. Options: gemini-3-pro | gemini-3-flash
GEMINI_MODEL=gemini-3-pro
# auto = use stub when key is missing | always = always stub | never = always real
GEMINI_STUB_MODE=auto

# ===== MongoDB =====
MONGODB_URI=mongodb://localhost:27017/agriguardian

# ===== MongoDB MCP (partner integration — required for hackathon track) =====
# Set to true after you start the `mongodb-mcp` sidecar (see docker-compose.yml).
MCP_MONGODB_ENABLED=false
MCP_MONGODB_URL=http://localhost:3000/mcp

# ===== App =====
PORT=8080
SPRING_PROFILES_ACTIVE=dev

